# 独立站建站-site-builder · 环境变量模板
# ----------------------------------------------------------------------
# 用法：
#   1. cp .env.example .env
#   2. 填入你自己申请的值（大部分可选）
#   3. .env 会被 .gitignore 排除，不会进 commit
# ----------------------------------------------------------------------

# === 部署目标（必需） ===
# 用于 deployer MCP 把构建产物推到客户的服务器
DEPLOY_SSH_USER=
DEPLOY_SSH_HOST=
DEPLOY_SSH_PORT=22
DEPLOY_SSH_KEY_PATH=~/.ssh/id_ed25519
# 如果无法用 key 只能用密码，建议用 base64 编码防肉眼偷窥
# DEPLOY_SSH_PASSWORD_BASE64=

# === Cloudflare（可选，用于 AI Advisor Worker 和 Pages 部署） ===
# 1. 到 https://dash.cloudflare.com/profile/api-tokens
# 2. 创建 Token（权限：Workers Scripts:Edit / Account:Read）
# 3. 把 Token + Account ID 填入下面
CF_API_TOKEN=
CF_ACCOUNT_ID=

# === Anthropic（可选，仅当启用 features.aiAdvisor 时） ===
# AI Advisor 后端 Worker 需要调用 Claude API
# 1. 到 https://console.anthropic.com 创建 key
# 2. 建议用 wrangler secret 管理：`wrangler secret put ANTHROPIC_API_KEY`
# 3. 本地开发时填这里
ANTHROPIC_API_KEY=

# === Web3Forms（可选，Contact 表单后端） ===
# 1. 到 https://web3forms.com 注册（邮箱验证）
# 2. 复制 access key
# 建议为每个客户申请独立的 access key
WEB3FORMS_ACCESS_KEY=

# === IndexNow（索引加速，免费） ===
# 1. 到 https://www.bing.com/indexnow 生成 key
# 2. <key>.txt 放到客户站 public/ 目录（build-execution 技能会自动处理）
INDEXNOW_KEY=

# === 图片生成（可选，image-generator MCP） ===
# 用于生成博客封面、信息图、产品占位（不用于产品本体）
# 配置参考 image-generator MCP 的文档
IMAGE_GEN_API_KEY=

# === Brightdata（可选，竞品抓取） ===
# 用于抓反爬严重的阿里国际站等
# 1. 到 https://brightdata.com 注册（5000 次/月免费档）
BRIGHTDATA_API_KEY=

# === Apollo（可选，潜在客户发现，未来激活） ===
APOLLO_API_KEY=
